{
  "format_version": "1.26.10",
  "particle_effect": {
    "description": {
      "identifier": "minecraft:ink_emitter",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/particles"
      }
    },
    "components": {
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": {
          "expression": "(variable.emitter_age > 0.45 ? 1.0 : 0.0)",
          "version": 1
        },
        "expiration_expression": {
          "expression": "(variable.emitter_age > 10.0 ? 1.0 : 0.0)",
          "version": 1
        }
      },
      "minecraft:emitter_rate_instant": {
        "num_particles": {
          "expression": "variable.particlecount",
          "version": 1
        }
      },
      "minecraft:emitter_shape_point": {
        "direction": [
          {
            "expression": "variable.direction_vector.x + Math.random(0, 1) * variable.aabb_dimension.x * 2 - variable.aabb_dimension.x",
            "version": 1
          },
          {
            "expression": "variable.direction_vector.y + 0.5 + Math.random(0, 1) * variable.aabb_dimension.y",
            "version": 1
          },
          {
            "expression": "variable.direction_vector.z + Math.random(0, 1) * variable.aabb_dimension.x * 2 - variable.aabb_dimension.x",
            "version": 1
          }
        ]
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          {
            "expression": "variable.particlesize",
            "version": 1
          },
          {
            "expression": "variable.particlesize",
            "version": 1
          }
        ],
        "facing_camera_mode": "rotate_xyz",
        "direction": {
          "mode": "derive_from_velocity",
          "custom_direction": [
            0,
            0,
            0
          ],
          "min_speed_threshold": 0.1
        },
        "uv": {
          "texture_width": 128,
          "texture_height": 128,
          "uv": [
            0,
            0
          ],
          "uv_size": [
            1,
            1
          ],
          "flipbook": {
            "base_UV": [
              56,
              0
            ],
            "size_UV": [
              8,
              8
            ],
            "step_UV": [
              -8,
              0
            ],
            "frames_per_second": 8,
            "max_frame": 8,
            "stretch_to_lifetime": true
          }
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "gradient": {
            "0.000000": [
              {
                "expression": "variable.color.r + Math.random(0, 0.05)",
                "version": 1
              },
              {
                "expression": "variable.color.g + Math.random(0, 0.05)",
                "version": 1
              },
              {
                "expression": "variable.color.b + Math.random(0, 0.05)",
                "version": 1
              },
              1
            ]
          },
          "interpolant": 0
        }
      },
      "minecraft:particle_initial_speed": {
        "expression": "(1.0 + Math.random(0, 1) + Math.random(0, 1))",
        "version": 1
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": {
          "expression": "(variable.particlesize * 4) / (Math.random(0.2, 1))",
          "version": 1
        }
      },
      "minecraft:particle_motion_collision": {
        "collision_drag": 4,
        "collision_radius": 0.1,
        "events": []
      },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          0,
          {
            "expression": "variable.is_outside_water * (-3)",
            "version": 1
          },
          0
        ],
        "linear_drag_coefficient": 1.5
      }
    }
  }
}